# ═══════════════════════════════════════════════════════════════════
# Plantilla — frontend/.env.local.serverlm-corp
# ═══════════════════════════════════════════════════════════════════
# Cómo usar:
#   1. Copia este archivo a frontend/.env.local.serverlm-corp (sin .example)
#   2. Reemplaza cada placeholder con el valor real de tu gestor
#   3. .env.local.serverlm-corp NO se commitea (gitignored por `.env*`)
#
# Este archivo se usa para correr `npm run dev` localmente apuntando al
# backend de producción `serverlm-corp`. NO se sube a Vercel —
# en Vercel las variables se configuran en el panel.
# ═══════════════════════════════════════════════════════════════════

# URL del proyecto Supabase serverlm-corp
NEXT_PUBLIC_SUPABASE_URL=https://uswliiylrlowiomkvfid.supabase.co

# Clave anónima de Supabase (Settings → API Keys → Legacy → anon)
NEXT_PUBLIC_SUPABASE_ANON_KEY=<copiar de tu gestor: SUPABASE_ANON_KEY>

# URL del backend FastAPI en Railway (cuando lo creemos en Fase B)
# Por ahora apunta a la URL que Railway le asigne al servicio serverlm-corp-backend
NEXT_PUBLIC_API_URL=https://serverlm-corp-backend-production.up.railway.app
